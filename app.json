{
  "expo": {
    "name": "MoMoney",
    "slug": "budgeting-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "receiptbudget",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.receiptbudget.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Kamera dipakai untuk scan struk dan mencatat pengeluaran secara otomatis.",
        "NSPhotoLibraryUsageDescription": "Akses galeri dipakai untuk memilih foto struk yang ingin di-scan.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.receiptbudget.app",
      "adaptiveIcon": {
        "backgroundColor": "#B07D56",
        "foregroundImage": "./assets/adaptive-foreground.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Izinkan MoMoney memakai kamera untuk scan struk."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Izinkan MoMoney mengakses galeri untuk memilih foto struk."
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FBF6F0"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      "./plugins/withDisableScriptSandboxing",
      "./plugins/withNoPushEntitlement",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "b802fb9c-c193-4dbd-8ba9-36a4a47083eb"
      }
    }
  }
}
